    {{ template "counter.tmpl" }}

    <div class="container main p-5">
      <h2 class="text-break">{{ .Title }}</h2>

      <br />
      <br />

      <form action="/poll/{{ .Id }}" method="POST">
      {{ if eq .PollType "simple" }}
        {{ range $i, $option := .Options }}
        <div class="form-check fs-4 lh-sm">
          <input class="form-check-input" type="radio" name="option" id="{{ $option }}" value="{{ $option }}" />
          <label class="form-check-label" for="{{ $option }}">{{ $option }}</label>
        </div>
        <br />
        {{ end }}
        {{ if .AllowWriteIns }}
        <div class="form-check fs-4 lh-sm">
          <input class="form-check-input" type="radio" name="option" value="writein" />
          <input
            type="text"
            name="writeinOption"
            class="form-control"
            placeholder="Write-In"
          />
        </div>
        {{ end }}
      {{ end }}

      {{ if eq .PollType "ranked" }}
        {{ $rankedMax := .RankedMax }}
        {{ range $i, $option := .Options }}
        <div class="form-check d-inline-flex align-items-center my-2">
          <div>
            <input
              type="number"
              name="{{ $option }}"
              id="{{ $option }}"
              class="form-control"
              min="0"
              max="{{ $rankedMax }}"
              style="min-width: 70px"
            />
          </div>
          <div class="mx-4">
            <label class="form-check-label" for="{{ $option }}">{{ $option }}</label>
          </div>
        </div>
        <br />
        {{ end }}
        {{ if .AllowWriteIns }}
          <div class="form-check d-inline-flex my-2">
            <div>
              <input
                type="number"
                name="writein"
                class="form-control"
                min="0"
                max="{{ $rankedMax }}"
                style="min-width: 70px"
              />
            </div>
            <div class="form-check">
              <input
                type="text"
                name="writeinOption"
                class="form-control"
                placeholder="Write-In"
                style="min-width: 170px"
              />
            </div>
        </div>
        {{ end }}
      {{ end }}
        <br />
        <button type="submit" class="btn btn-primary my-4 mx-4">Submit</button>
      </form>
      {{ if and (.CanModify) (not .Gatekeep) }}
        <form action="/poll/{{ .Id }}/close" method="POST">
          <button type="submit" class="btn btn-danger my-3 mx-4">End Poll</button>
        </form>
      {{ end }}
    </div>
  </body>
</html>